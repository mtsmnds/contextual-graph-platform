{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true
    },
    "react-flow": {
      "type": "local",
      "command": [
        "npx",
        "@yeshsurya/react-flow-mcp-server"
      ],
      "enabled": true
    }
  }
}
